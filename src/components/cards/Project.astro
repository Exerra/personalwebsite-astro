---
interface Props {
    date?: number | string,
    name: string,
    description: string,
    href: string,
    label: string
}

const { date, name, description, href, label } = Astro.props
---

<div class={"w-full basis-1/1 grow lg:basis-1/3 shadow-2xl bg-beige text-grey-card rounded-sm p-6 flex flex-col justify-between border-l-4 border-accent"}>
    <div>
        <h2 class="text-3xl lg:text-4xl font-black uppercase tracking-tight">{name}</h2>
        <hr class="border-2 border-grey-card/20 my-3" />
        <p class="text-xl mb-4" set:html={description} />
    </div>
    <a href={href} target={"_blank"} class={"transition ease-in-out text-accent font-bold uppercase tracking-wider text-sm hover:text-grey-card after:content-['_↗']"}>{label}</a>
</div>