---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<Layout title="Blog - Exerra" description="Blog posts by Exerra, a full-stack developer from Latvia.">
	<Navbar />
	<div class="max-w-3xl mx-auto px-6 py-12">
		<h1 class="text-4xl md:text-5xl font-bold text-grey-card mb-8">Blog</h1>
		<div class="flex flex-col gap-8">
			{posts.map((post) => (
				<a href={`/blog/${post.id}`} class="group block">
					<article class="bg-white/50 rounded-2xl p-6 shadow-md transition hover:shadow-lg">
						<h2 class="text-2xl font-bold text-grey-card group-hover:text-selected-text transition">{post.data.title}</h2>
						<p class="text-grey-card/60 mt-1 text-sm">
							{post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
						</p>
						<p class="text-grey-card/80 mt-3">{post.data.description}</p>
					</article>
				</a>
			))}
		</div>
	</div>
</Layout>
